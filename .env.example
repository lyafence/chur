# chur environment variables
# Copy to .env and adjust for local development.

# (webhook) Listen address (host:port)
CHUR_LISTEN=:8443

# (webhook) Listen address (host:port) for health/readiness probes
CHUR_HEALTH_LISTEN=:8080

# (webhook) TLS mode: server = no client cert (default), mtls = require + verify client cert
CHUR_TLS_MODE=server

# (webhook) Auto-generate self-signed TLS cert when cert files are not mounted (dev only)
# Set to 1 to enable. The cert is written to a temp directory.
# CHUR_TLS_AUTO_GENERATE=1
# (webhook) DNS name for the auto-generated cert (only when CHUR_TLS_AUTO_GENERATE=1)
# Default: localhost
# CHUR_TLS_CERT_DNS_NAME=localhost

# (webhook) Path to CA certificate for verifying API server client cert (mtls mode only)
# Default: /etc/chur/ca.crt. Must be a PEM-encoded CA bundle.
# Only used when CHUR_TLS_MODE=mtls.
CHUR_CLIENT_CA_PATH=/etc/chur/ca.crt

# (init) Secret provider name: env, local, k8s
CHUR_PROVIDER=env

# (init) Volume mount path for secrets
CHUR_MOUNT_PATH=/secrets

# (init) Secret reference name (e.g. env var name, file name, or k8s secret name)
CHUR_SECRET_REF=

# (init) Key within a JSON secret value (optional). When set, the init container
# parses the secret as JSON and returns the value of this key.
CHUR_SECRET_KEY=

# (webhook → init) Maximum secret size. The webhook reads this value and
# injects it into every chur-init container it creates.
CHUR_MAX_SECRET_SIZE=1Mi

# (webhook → init, local provider) Base directory for local file reads.
# Default: /etc/chur/secrets. In Kubernetes, mount a hostPath here or set
# chur.io/mount-path to match this value.
CHUR_LOCAL_BASE_PATH=/etc/chur/secrets

# (webhook) Max size of tmpfs volume per pod
CHUR_VOLUME_SIZE_LIMIT=10Mi

# (webhook) Comma-separated allowlist of namespaces (empty = all)
CHUR_ALLOWED_NAMESPACES=

# (webhook) Init container image (empty = binary default: ghcr.io/lyafence/chur-init:latest)
CHUR_INIT_IMAGE=

# (webhook) Maximum number of concurrent admission review requests.
# Default: 100. Increase with care: mutation is CPU-bound and unbounded
# concurrency can exhaust memory under cluster churn.
CHUR_MAX_CONCURRENT=100

# chur-keeper (optional binary)

# Listen address
# CHUR_KEEPER_LISTEN=:9443

# Health listen address (plain HTTP, default :9444)
# CHUR_KEEPER_HEALTH_LISTEN=:9444

# TLS mode: self-signed (dev, default) or mtls
# CHUR_KEEPER_TLS_MODE=self-signed

# DNS name for auto-generated self-signed certificate (dev only)
# CHUR_KEEPER_TLS_DNS_NAME=localhost

# Paths to TLS cert and key (required in mtls mode, optional in self-signed)
# CHUR_KEEPER_TLS_CERT=/etc/chur-keeper/tls.crt
# CHUR_KEEPER_TLS_KEY=/etc/chur-keeper/tls.key

# Path to client CA file for mTLS (required in mtls mode)
# CHUR_KEEPER_TLS_CLIENT_CA=/etc/chur-keeper/ca.crt

# Skip TLS certificate verification (dev only)
# CHUR_KEEPER_SKIP_VERIFY=1

# Backend type: filesystem (default) or exec
# CHUR_KEEPER_BACKEND=filesystem

# Maximum secret size (bytes or Ki/Mi/Gi)
# CHUR_KEEPER_MAX_SECRET_SIZE=1Mi

# (exec backend) Command to execute (ref passed as argument)
# CHUR_KEEPER_EXEC_COMMAND=/usr/local/bin/get-secret

# (exec backend) Command execution timeout in seconds (default 10)
# CHUR_KEEPER_EXEC_TIMEOUT=10

# (exec backend) Max stdout bytes (default 1Mi)
# CHUR_KEEPER_EXEC_MAX_STDOUT=1048576

# (filesystem backend) Root directory for file reads
# CHUR_KEEPER_BACKEND_FS_ROOT=/var/lib/chur-keeper/secrets

# keeper provider (init container)

# URL of the chur-keeper service
# CHUR_KEEPER_URL=https://chur-keeper:9443

# Skip TLS verify when calling keeper (dev only)
# CHUR_KEEPER_SKIP_VERIFY=1

# CA bundle for verifying chur-keeper server certificate (production alternative to skipVerify)
# CHUR_KEEPER_SERVER_CA=/etc/chur-keeper/ca.crt

# Client cert/key for mTLS when calling keeper
# CHUR_KEEPER_TLS_CERT=/etc/chur-keeper/client.crt
# CHUR_KEEPER_TLS_KEY=/etc/chur-keeper/client.key
