# chur — Environment Configuration
# Copy to .env and fill in your values.

# (webhook) Listen address (host:port) for admission
CHUR_LISTEN=:8443

# (webhook) Listen address (host:port) for health/readiness probes
CHUR_HEALTH_LISTEN=:8080

# (webhook) TLS mode: dev = no client cert, prod = require + verify client cert
CHUR_TLS_MODE=dev

# (init) Secret provider name: env, local, k8s
CHUR_PROVIDER=env

# (init) Reference passed to the provider (env var name, file name, k8s secret name)
CHUR_SECRET_REF=

# (init) Mount path for the tmpfs volume inside the container
CHUR_MOUNT_PATH=/secrets

# (k8s provider) Secret data key to extract when the secret has multiple keys
CHUR_SECRET_KEY=

# (webhook) Size limit for tmpfs volume (e.g. 10Mi, 100Mi, 1Gi)
CHUR_VOLUME_SIZE_LIMIT=10Mi

# (webhook) Comma-separated list of allowed namespaces; empty = allow all
CHUR_ALLOWED_NAMESPACES=

# (webhook) Init container image (default: ghcr.io/lyafence/chur-init:latest)
CHUR_INIT_IMAGE=

# (init) Max secret size in bytes or K8s quantity (e.g. 1Mi, 1048576)
CHUR_MAX_SECRET_SIZE=1Mi
