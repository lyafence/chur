#!/bin/sh
set -e

echo "🔍 pre-commit: checking Go formatting..."

unformatted=$(gofmt -l .)
if [ -n "$unformatted" ]; then
  echo "ERROR: unformatted Go files:"
  echo "$unformatted"
  exit 1
fi

echo "✅ format OK"

# Optional: scan for secrets with gitleaks
if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks dir --no-color --redact=100 . 2>/dev/null; then
    echo "⚠️  gitleaks: potential secrets detected (non-blocking)"
  fi
else
  echo "📋 gitleaks not installed — skipping secret scan"
fi
